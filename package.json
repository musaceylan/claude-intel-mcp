{
  "name": "claude-intel-mcp",
  "version": "1.0.0",
  "description": "AI-powered MCP server that continuously improves Claude Code by learning from high-signal GitHub repositories",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "claude-intel-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8",
    "better-sqlite3": "^9.4.3",
    "diff": "^5.2.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/diff": "^5.2.1",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
